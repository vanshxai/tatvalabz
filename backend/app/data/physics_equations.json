{
  "name": "Nassenger 8 Universal Graph Logic",
  "defaults": {
    "global_inputs": {
      "line_speed": 110.0,
      "target_rpm": 360.0,
      "heater_power": 210.0,
      "Tension": 0.0
    }
  },
  "nodes": [
    {
      "id": "line_feed",
      "title": "Line Feed",
      "category": "Inputs",
      "inputs": [
        "line_speed"
      ],
      "outputs": [
        "web_speed"
      ],
      "formulas": {
        "web_speed": "max(0, line_speed - (var('$V_feed__drag') * 5.0))"
      },
      "variables": {
        "$V_feed__drag": {
          "label": "Feed Drag",
          "min": 0,
          "max": 1,
          "step": 0.01,
          "default": 0
        }
      }
    },
    {
      "id": "printhead",
      "title": "Printhead Thermal",
      "category": "Thermal",
      "inputs": [
        "heater_power"
      ],
      "outputs": [
        "head_temp"
      ],
      "formulas": {
        "head_temp": "max(20, 26 + (heater_power * 0.5) - (var('$V_head__loss') * 68.0))"
      },
      "variables": {
        "$V_head__loss": {
          "label": "Heater Loss",
          "min": 0,
          "max": 1,
          "step": 0.01,
          "default": 0
        }
      }
    },
    {
      "id": "motor_01",
      "title": "Motor 01",
      "category": "Drive",
      "inputs": [
        "target_rpm",
        "web_speed",
        "Tension"
      ],
      "outputs": [
        "i",
        "Te",
        "omega"
      ],
      "formulas": {
        "i": "max(0, 1.4 + (target_rpm / 420.0) + (web_speed / 260.0) + (Tension / 85.0) + (var('$V_01__friction') * 3.1) + (var('$V_01__tension') * 1.9) + (var('Te') * 0.08))",
        "Te": "max(0, (0.48 * i) - (Tension * 0.015) - (var('$V_01__friction') * 0.42) - (var('$V_01__tension') * 0.18))",
        "omega": "max(0, target_rpm + (web_speed * 1.25) + (Te * 52.0) - (Tension * 1.35) - (var('$V_01__tension') * 130.0))"
      },
      "variables": {
        "$V_01__friction": {
          "label": "Motor 01 Friction",
          "min": 0,
          "max": 1,
          "step": 0.01,
          "default": 0
        },
        "$V_01__tension": {
          "label": "Motor 01 Tension",
          "min": 0,
          "max": 1,
          "step": 0.01,
          "default": 0
        }
      }
